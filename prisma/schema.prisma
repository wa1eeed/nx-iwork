// ============================================
// NX iWork - Database Schema (Complete)
// ============================================
// Dual-Mode SaaS + Single-Tenant
// 3-Layer Memory System + BYOK
// 
// Run: npx prisma generate && npx prisma migrate dev --name init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm, pgcrypto]
}

// ========================================
// USERS & AUTH
// ========================================

enum UserRole {
  SUPER_ADMIN       // وليد (مالك المنصة)
  BUSINESS_OWNER    // صاحب الشركة المشتركة
  BUSINESS_MEMBER   // موظف بشري في شركة
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String
  password         String
  role             UserRole  @default(BUSINESS_OWNER)
  image            String?
  locale           String    @default("ar")
  twoFactorEnabled Boolean   @default(false)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  sessions          Session[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  approvalsResolved Approval[] @relation("ApprovalResolver")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@index([companyId])
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========================================
// COMPANY (TENANT)
// ========================================

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

model Company {
  id              String        @id @default(cuid())
  name            String
  nameEn          String?
  slug            String        @unique
  logo            String?
  industry        String?
  teamSize        String?
  mainGoal        String?
  vision          String?       @db.Text
  brandVoice      String?       @db.Text
  status          CompanyStatus @default(TRIAL)
  trialEndsAt     DateTime?

  // Plan the owner selected during onboarding. Recorded for now; real billing
  // (Tap) is wired later. Everyone starts on managed token credits regardless.
  plan            PlanTier      @default(STARTER)

  // Managed billing (AI_MODE=managed): prepaid AI token credits. The platform
  // pays the provider and decrements this per request; at <= 0 requests are
  // blocked. Ignored in BYOK mode (the company's own key is billed directly).
  // Default is a small trial grant so new managed tenants can try immediately.
  tokenBalance    Int           @default(100000)

  // Modular architecture: the owner enables only the modules their business
  // needs. Drives the sidebar, pages, and which AI tools the agents receive.
  hasEcommerce    Boolean       @default(true)   // Product catalog + cart
  hasServices     Boolean       @default(true)   // On-demand services
  hasBookings     Boolean       @default(false)  // Appointments / availability

  // Custom domain support
  customDomain         String?  @unique
  customDomainVerified Boolean  @default(false)
  customDomainSslReady Boolean  @default(false)

  // Relations
  users               User[]
  departments         Department[]
  agents              Agent[]
  tasks               Task[]
  taskAttempts        TaskAttempt[]
  approvals           Approval[]
  chatMessages        ChatMessage[]
  subscription        Subscription?
  invoices            Invoice[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  companyDNA          CompanyDNA?
  apiSettings         CompanyApiSettings?
  settings            BusinessSettings?
  websiteConfig       WebsiteConfig?
  timelineEvents      TimelineEvent[]
  agentMemories       AgentMemory[]
  agentSchedules      AgentSchedule[]
  services            Service[]
  products            Product[]
  bookings            Booking[]
  orders              Order[]
  customers           Customer[]
  faqItems            FaqItem[]
  eventTriggers       EventTrigger[]
  refCounters         RefCounter[]
  publicConversations PublicConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([slug])
  @@index([customDomain])
}

model CompanyDNA {
  id             String   @id @default(cuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  aboutUs        String   @db.Text
  products       Json?    // [{name, desc, price}]
  policies       String?  @db.Text
  tone           String?
  targetAudience String?  @db.Text
  
  // Operating procedures
  operationsManual String? @db.Text
  decisionPolicies String? @db.Text  // ما يقدر الـ agents يقررونه وحدهم
  
  updatedAt      DateTime @updatedAt
}

// ========================================
// BUSINESS SETTINGS (Configurable)
// ========================================

model BusinessSettings {
  id              String   @id @default(cuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Language
  primaryLanguage    String   @default("ar")           // ar, en
  showLanguageToggle Boolean  @default(true)
  enabledLanguages   String[] @default(["ar", "en"])

  // Currency
  currency       String  @default("SAR")
  currencySymbol String  @default("ر.س")

  // Date & Time
  dateFormat    String  @default("DD/MM/YYYY")
  showHijriDate Boolean @default(true)
  timezone      String  @default("Asia/Riyadh")
  weekStart     String  @default("sunday")           // sunday, monday, saturday

  // Theme
  themeMode    String @default("dark")               // dark, light, system
  primaryColor String @default("#06b6d4")
  accentColor  String @default("#8b5cf6")

  // Branding
  showPoweredBy Boolean @default(true)
  customCSS     String? @db.Text

  // Notifications preferences
  emailNotifications    Boolean @default(true)
  desktopNotifications  Boolean @default(true)

  // Escalation channel: owner's Telegram bot for human-in-the-loop alerts
  // (e.g. an angry-customer complaint that an agent escalates).
  telegramBotToken      String?
  telegramChatId        String?

  updatedAt DateTime @updatedAt
}

// ========================================
// DEPARTMENTS & AGENTS
// ========================================

model Department {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name        String
  nameEn      String?
  icon        String   @default("briefcase")
  description String?  @db.Text
  color       String   @default("#06b6d4")

  agents Agent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

enum AgentStatus {
  ONBOARDING // being cognitively onboarded; not yet serving
  ONLINE     // active
  WORKING
  PAUSED
  OFFLINE
  ARCHIVED
}

enum ClaudeModel {
  HAIKU
  SONNET
  OPUS
}

model Agent {
  id           String      @id @default(cuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name         String
  nameEn       String?
  avatar       String?
  initial      String
  ref          String?     // AGT-001 (per-company)
  
  role         String
  roleEn       String?
  persona      String      @db.Text

  // Agent lifecycle system: hybrid creation (from a system template or custom),
  // structured KPIs, and a rolling performance score (0–100).
  templateId       String?
  template         AgentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  isCustom         Boolean        @default(true)
  kpis             Json?          // [{ key, label, target, unit }]
  performanceScore Float          @default(100)

  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  parentId     String?
  parent       Agent?      @relation("AgentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subordinates Agent[]     @relation("AgentHierarchy")
  
  // AI Configuration
  model        ClaudeModel @default(SONNET)
  temperature  Float       @default(0.7)
  maxTokens    Int         @default(4096)
  systemPrompt String?     @db.Text
  
  // Capabilities
  skills       AgentSkill[]
  tools        AgentTool[]
  
  // Memory
  memories     AgentMemory[]

  // Schedules
  schedules    AgentSchedule[]

  // CRM leads this agent owns/handles
  assignedCustomers Customer[] @relation("AgentCustomers")

  // Event triggers that wake this agent
  eventTriggers     EventTrigger[]
  
  // Activity
  status            AgentStatus @default(ONLINE)
  tasks             Task[]
  taskAttempts      TaskAttempt[]
  approvals         Approval[]
  chatMessages      ChatMessage[]
  publicConversations PublicConversation[]
  timeline          TimelineEvent[]

  // Statistics
  tasksCompleted   Int @default(0)
  tasksFailed      Int @default(0)
  totalTokensUsed  Int @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@index([companyId])
  @@index([departmentId])
  @@index([parentId])
  @@index([status])
}

// Reusable, platform-wide blueprints an owner can spin a ready-made AI employee
// from (Sales / Support / Marketing / …). The hybrid-creation path copies a
// template into a tenant-scoped Agent and materializes its scenarios.
model AgentTemplate {
  id                 String  @id @default(cuid())
  templateType       String  @unique // 'sales' | 'support' | 'marketing' | ...
  roleName           String
  roleNameEn         String
  department         String
  departmentEn       String
  roleDescription    String  @db.Text
  roleDescriptionEn  String  @db.Text

  // Structured persona traits, e.g. { tone, traits[], priorities[] }.
  personalityProfile Json
  coreInstructions   String  @db.Text
  // [{ event, action }] — events matching TriggerEvent are materialized as
  // live EventTriggers on creation; others are kept for reference/roadmap.
  ifThenScenarios    Json
  defaultKpis        Json    // [{ key, label, target, unit }]
  defaultPermissions Json    // ['search_catalog', 'create_lead', ...] (tool ids)
  model              ClaudeModel @default(HAIKU)
  icon               String  @default("bot")
  accent             String  @default("#06b6d4")
  sortOrder          Int     @default(0)
  isActive           Boolean @default(true)

  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================================
// 3-LAYER MEMORY
// ========================================

// Layer 3: Semantic Memory (Vector Embeddings)
model AgentMemory {
  id        String  @id @default(cuid())
  agentId   String
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  summary    String                       @db.Text
  embedding  Unsupported("vector(1536)")?
  
  importance Int     @default(5)         // 1-10
  category   String?                     // 'customer', 'product', 'decision', 'learning'
  
  metadata   Json?
  
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  
  @@index([agentId])
  @@index([companyId])
  @@index([category])
}

// ========================================
// SKILLS & TOOLS
// ========================================

model Skill {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  nameEn         String
  description    String   @db.Text
  descriptionEn  String   @db.Text
  icon           String   @default("sparkle")
  
  isSaudi        Boolean  @default(false)
  isPremium      Boolean  @default(false)
  isActive       Boolean  @default(true)
  
  promptTemplate String?  @db.Text
  category       String?
  
  usersCount     Int      @default(0)
  rating         Float    @default(0)

  agents         AgentSkill[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

model AgentSkill {
  agentId String
  skillId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@id([agentId, skillId])
  @@index([skillId])
}

enum ToolType {
  CLAUDE_TOOL      // built-in
  N8N_WORKFLOW     // external n8n
  INTERNAL_API     // internal NX iWork API
  CUSTOM_HTTP      // custom webhook
}

model Tool {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  nameEn      String?
  description String   @db.Text
  
  type        ToolType
  schema      Json     // JSON schema for inputs
  
  // For N8N_WORKFLOW
  webhookUrl  String?
  
  // For INTERNAL_API
  handler     String?
  
  // For CUSTOM_HTTP
  httpMethod  String?
  httpUrl     String?
  httpHeaders Json?
  
  isActive    Boolean  @default(true)
  
  agents      AgentTool[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AgentTool {
  agentId String
  toolId  String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tool    Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  
  config  Json?  // tool-specific configuration
  
  @@id([agentId, toolId])
  @@index([toolId])
}

// ========================================
// SCHEDULES (Wake triggers - cron based)
// ========================================

model AgentSchedule {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  
  cronExpression String  // e.g., "0 8 * * *" = 8 AM daily
  timezone       String  @default("Asia/Riyadh")
  
  taskTemplate   String  @db.Text  // The prompt sent to the agent
  
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  runCount       Int       @default(0)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([agentId])
  @@index([nextRunAt])
}

// ========================================
// TASKS & ATTEMPTS
// ========================================

enum TaskStatus {
  PENDING            // لم يبدأ
  WORKING            // يشتغل عليه
  PENDING_APPROVAL   // ينتظر موافقة
  PENDING_REVIEW     // ينتظر مراجعة
  BLOCKED            // متوقف
  DONE               // منجز
  FAILED             // فشل بعد محاولات
  CANCELLED          // ملغى
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// One unified table backs three things the UI renders as a list or a calendar:
//   AGENT_TASK  - work an AI employee performs (default)
//   APPOINTMENT - a customer-facing booking/meeting (uses startAt/endAt)
//   REMINDER    - a simple dated nudge for the owner/team
enum TaskKind {
  AGENT_TASK
  APPOINTMENT
  REMINDER
}

model Task {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Optional: APPOINTMENT/REMINDER kinds may not belong to any agent. When an
  // agent is deleted its tasks survive (SetNull) so history/calendar stay intact.
  agentId       String?
  agent         Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)

  kind          TaskKind     @default(AGENT_TASK)

  // Optional link to the CRM record this task/appointment is about.
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  title         String
  description   String       @db.Text
  notes         String?      @db.Text

  status        TaskStatus   @default(PENDING)
  priority      TaskPriority @default(MEDIUM)
  progress      Int          @default(0)

  // Trigger source
  triggerType   String       // USER_MESSAGE, TASK_ASSIGNMENT, SCHEDULE, WEBHOOK, INTER_AGENT
  triggerSource Json?

  // Calendar window (used by APPOINTMENT; optional for others).
  startAt       DateTime?
  endAt         DateTime?

  // Activity-specific attributes (e.g. location, party_size, channel).
  customFields  Json?

  // Execution
  startedAt     DateTime?
  dueAt         DateTime?
  completedAt   DateTime?
  result        String?      @db.Text
  
  // Hierarchy
  parentTaskId  String?
  parentTask    Task?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks      Task[]       @relation("TaskHierarchy")
  
  // Stats
  tokensUsed    Int          @default(0)
  
  // Relations
  attempts      TaskAttempt[]
  approvals     Approval[]
  
  // Who assigned
  assignedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, kind])
  @@index([agentId])
  @@index([customerId])
  @@index([status])
  @@index([dueAt])
  @@index([startAt])
  @@index([parentTaskId])
}

enum AttemptStatus {
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model TaskAttempt {
  id            String        @id @default(cuid())
  taskId        String
  task          Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentId       String
  agent         Agent         @relation(fields: [agentId], references: [id])
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  attemptNumber Int
  status        AttemptStatus
  
  errorReason   String?       @db.Text
  errorType     String?       // 'API_LIMIT', 'PERMISSION', 'EXTERNAL_API_ERROR', 'VALIDATION', 'OTHER'
  retryable     Boolean       @default(true)
  
  startedAt     DateTime
  endedAt       DateTime?
  
  tokensUsed    Int           @default(0)
  metadata      Json?
  
  createdAt     DateTime      @default(now())

  @@index([taskId, attemptNumber])
  @@index([agentId])
  @@index([companyId])
  @@index([status])
}

// ========================================
// APPROVALS (Inbox)
// ========================================

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Approval {
  id           String         @id @default(cuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId      String
  agent        Agent          @relation(fields: [agentId], references: [id])
  taskId       String?
  task         Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  decision     String         @db.Text
  options      Json           // ["approve", "reject"] or custom options
  context      String?        @db.Text
  metadata     Json?
  
  status       ApprovalStatus @default(PENDING)
  resolution   String?
  resolvedById String?
  resolvedBy   User?          @relation("ApprovalResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  notes        String?        @db.Text
  
  expiresAt    DateTime?
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([companyId, status])
  @@index([agentId])
}

// ========================================
// CHAT MESSAGES
// ========================================

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

model ChatMessage {
  id         String      @id @default(cuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId    String
  agent      Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  role       MessageRole
  content    String      @db.Text
  userId     String?
  
  tokensUsed Int         @default(0)
  model      String?
  metadata   Json?
  
  createdAt  DateTime    @default(now())

  @@index([companyId])
  @@index([agentId, createdAt])
}

// ========================================
// CRM (Customers / Leads)
// ========================================

enum LeadStatus {
  NEW         // جديد
  INTERESTED  // مهتم
  NEGOTIATING // قيد التفاوض
  WON         // اشترى / تم
  LOST        // مفقود
}

// A human customer/lead of the business. Distinct from User (platform accounts)
// and from the inline customer fields on Order — this is the persistent CRM
// record agents create and update as they talk to people.
model Customer {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ref    String?     // CUS-001 (per-company)
  name   String
  email  String?
  phone  String?

  status LeadStatus @default(NEW)
  source String?    // 'chat_widget' | 'manual' | 'agent' | 'public_form' | ...

  notes  String?    @db.Text

  // Activity-specific attributes (e.g. budget, preferred_district, party_size).
  // Same flexible-field strategy as Service/Product.
  customFields Json?

  // The agent responsible for this lead, if any.
  assignedAgentId String?
  assignedAgent   Agent?  @relation("AgentCustomers", fields: [assignedAgentId], references: [id], onDelete: SetNull)

  tasks    Task[]
  orders   Order[]
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([assignedAgentId])
  @@index([phone])
}

// ========================================
// BOOKINGS MODULE (appointments / availability)
// ========================================

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// A customer booking a time slot. Enabled per company via Company.hasBookings.
model Booking {
  id         String        @id @default(cuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  ref        String?       // BKG-001 (per-company)
  title      String
  startAt    DateTime
  endAt      DateTime?
  status     BookingStatus @default(CONFIRMED)
  notes      String?       @db.Text

  // Activity-specific attributes (resource, party_size, service_type, …).
  customFields Json?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([companyId, startAt])
  @@index([customerId])
}

// ========================================
// HUMAN-READABLE REFERENCE CODES (per-tenant sequential)
// ========================================

// Per-company, per-entity counter for friendly codes like CUS-001, PRD-014.
// The real primary keys stay globally-unique cuids; `ref` is a display code that
// never collides because it's namespaced by company + entity and sequential.
model RefCounter {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entity    String  // 'customer' | 'product' | 'service' | 'booking' | 'agent'
  value     Int     @default(0)

  @@unique([companyId, entity])
}

// ========================================
// KNOWLEDGE BASE (FAQ) — structured, agent-readable
// ========================================

// Question/answer pairs the agents read via the search_faq tool. Structured
// (not PDF) so answers are exact and cheap on tokens.
model FaqItem {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  question  String
  answer    String   @db.Text
  category  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ========================================
// EVENT TRIGGERS (proactive automation)
// ========================================

enum TriggerEvent {
  LEAD_CREATED       // عميل جديد دخل الـ CRM
  ORDER_CREATED      // طلب جديد
  ORDER_PAID         // فاتورة مدفوعة
  CART_ABANDONED     // سلة متروكة
  COMPLAINT_RECEIVED // شكوى/غضب عميل
}

// "When EVENT happens, wake AGENT with this task." The dispatcher (lib/agent/
// events.ts) creates a PENDING task for the agent; the scheduler/cron runs it.
model EventTrigger {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId      String
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  event        TriggerEvent
  name         String
  taskTemplate String       @db.Text
  isActive     Boolean      @default(true)

  lastFiredAt  DateTime?
  fireCount    Int          @default(0)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([companyId, event])
  @@index([agentId])
}

// ========================================
// PUBLIC FRONTEND (Services, Products, Orders)
// ========================================

model Service {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ref           String?  // SRV-001 (per-company)
  title         String
  titleEn       String?
  description   String   @db.Text
  descriptionEn String?  @db.Text
  
  icon          String?
  image         String?
  
  price         Decimal? @db.Decimal(10, 2)
  priceLabel    String?
  
  ctaText       String   @default("اطلب الخدمة")
  ctaTextEn     String   @default("Request Service")

  // Activity-specific attributes the agent can read/filter on (e.g. duration,
  // area_sqm, bedrooms, check_in_time). Keeps the platform fit-for-any-business
  // without a schema change per vertical. Shape: { "key": value, ... }.
  customFields  Json?

  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  orders        Order[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

model Product {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ref           String?  // PRD-001 (per-company)
  title         String
  titleEn       String?
  description   String   @db.Text
  descriptionEn String?  @db.Text
  
  images        String[]
  
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  
  sku           String?
  stock         Int      @default(-1)  // -1 = unlimited

  // See Service.customFields — same purpose for products (e.g. color, size,
  // warranty_months, model_year).
  customFields  Json?

  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  orderItems    OrderItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

enum OrderType {
  SERVICE
  PRODUCT
}

enum OrderStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model Order {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  orderNumber  String        @unique
  
  type         OrderType
  
  // Customer info (kept inline so an order is self-contained even with no CRM
  // record; customerId links to the persistent CRM Customer when one exists).
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerEmail String?
  customerPhone String?
  customerNotes String?      @db.Text
  
  // Service order
  serviceId    String?
  service      Service?      @relation(fields: [serviceId], references: [id])
  
  // Product order
  items        OrderItem[]
  
  // Totals
  subtotal     Decimal       @db.Decimal(10, 2) @default(0)
  vat          Decimal       @db.Decimal(10, 2) @default(0)
  total        Decimal       @db.Decimal(10, 2) @default(0)
  currency     String        @default("SAR")
  
  status        OrderStatus   @default(NEW)
  paymentStatus PaymentStatus @default(PENDING)
  
  // Source tracking
  agentId      String?       // if came through agent chat
  conversationId String?     // public conversation ID
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  @@index([orderId])
}

// ========================================
// WEBSITE CONFIG (Public Frontend Settings)
// ========================================

enum HeroType {
  IMAGE
  SLIDER
  VIDEO
  TEXT_ONLY
}

model WebsiteConfig {
  id          String   @id @default(cuid())
  companyId   String   @unique
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Hero
  heroType       HeroType @default(IMAGE)
  heroTitle      String?
  heroTitleEn    String?
  heroSubtitle   String?  @db.Text
  heroSubtitleEn String?  @db.Text
  heroCTA        String?
  heroCTAEn      String?
  heroImages     String[]
  heroVideo      String?
  
  // About
  aboutTitle     String?
  aboutTitleEn   String?
  aboutContent   String?  @db.Text
  aboutContentEn String?  @db.Text
  
  // Contact
  whatsapp       String?
  phone          String?
  email          String?
  address        String?  @db.Text
  
  // Social
  instagram      String?
  twitter        String?
  tiktok         String?
  linkedin       String?
  snapchat       String?
  
  // SEO
  metaTitle      String?
  metaDescription String?
  ogImage        String?
  
  // Chat Widget
  chatEnabled       Boolean @default(true)
  chatAgentId       String?
  chatPosition      String  @default("bottom-right")
  chatGreeting      String?
  chatGreetingEn    String?
  chatPrimaryColor  String?
  
  // Display flags
  showServices    Boolean @default(true)
  showProducts    Boolean @default(true)
  showAbout       Boolean @default(true)
  showContact     Boolean @default(true)
  
  updatedAt   DateTime @updatedAt
}

// ========================================
// PUBLIC CONVERSATIONS (Visitors → Agents)
// ========================================

model PublicConversation {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id])
  
  // Visitor info
  visitorId       String
  visitorName     String?
  visitorEmail    String?
  visitorPhone    String?
  
  // Session
  sessionStarted  DateTime @default(now())
  lastMessageAt   DateTime @default(now())
  ended           Boolean  @default(false)
  
  // Outcome
  resultedInOrder Boolean  @default(false)
  orderId         String?
  
  // Analytics
  pageUrl         String?
  referrer        String?
  userAgent       String?
  ipAddress       String?
  country         String?
  
  messages        PublicMessage[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, sessionStarted])
  @@index([visitorId])
  @@index([agentId])
}

model PublicMessage {
  id              String              @id @default(cuid())
  conversationId  String
  conversation    PublicConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  role            MessageRole
  content         String              @db.Text
  
  tokensUsed      Int                 @default(0)
  metadata        Json?
  
  createdAt       DateTime            @default(now())

  @@index([conversationId, createdAt])
}

// ========================================
// TIMELINE
// ========================================

enum TimelineEventType {
  TASK_CREATED
  TASK_STARTED
  TASK_COMPLETED
  TASK_FAILED
  TASK_BLOCKED
  AGENT_MESSAGE
  AGENT_HANDOFF
  DECISION_NEEDED
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  MEMORY_SAVED
  SYSTEM_ALERT
  INTEGRATION_TRIGGERED
  AGENT_WOKE
  AGENT_SLEPT
}

model TimelineEvent {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId     String?
  agent       Agent?            @relation(fields: [agentId], references: [id], onDelete: SetNull)
  
  type        TimelineEventType
  title       String
  description String?           @db.Text
  metadata    Json?
  
  createdAt   DateTime          @default(now())

  @@index([companyId, createdAt])
  @@index([agentId])
}

// ========================================
// API SETTINGS (BYOK)
// ========================================

model CompanyApiSettings {
  id            String      @id @default(cuid())
  companyId     String      @unique
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // BYOK
  byokApiKey    String?     // ENCRYPTED with AES-256-GCM
  byokProvider  String      @default("anthropic")
  byokVerified  Boolean     @default(false)
  byokLastTest  DateTime?
  
  // Model preferences
  defaultModel  ClaudeModel @default(SONNET)
  allowedModels String[]    @default(["HAIKU", "SONNET", "OPUS"])
  
  // Optional limits
  monthlyCapUsd Decimal?    @db.Decimal(10, 2)
  
  updatedAt     DateTime    @updatedAt
}

// ========================================
// SUBSCRIPTIONS & BILLING (SaaS phase)
// ========================================

enum PlanTier {
  FREE
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Plan {
  id                String   @id @default(cuid())
  tier              PlanTier @unique
  name              String
  nameEn            String
  description       String?  @db.Text
  
  priceMonthly      Decimal  @db.Decimal(10, 2)
  priceYearly       Decimal  @db.Decimal(10, 2)
  
  // Limits
  maxAgents         Int
  maxDepartments    Int
  maxMembers        Int
  maxProducts       Int      @default(-1)  // -1 = unlimited
  maxServices       Int      @default(-1)
  
  // Features
  allowCustomDomain Boolean  @default(false)
  allowCustomBranding Boolean @default(false)
  allowApiAccess    Boolean  @default(false)
  allowN8nIntegration Boolean @default(false)
  prioritySupport   Boolean  @default(false)
  
  features          Json     // array of feature labels
  
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)

  subscriptions     Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id                     String             @id @default(cuid())
  companyId              String             @unique
  company                Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId                 String
  plan                   Plan               @relation(fields: [planId], references: [id])
  
  status                 SubscriptionStatus @default(TRIAL)
  
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAt               DateTime?
  cancelledAt            DateTime?
  
  interval               String             @default("month")

  invoices               Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  FAILED
  REFUNDED
}

model Invoice {
  id                String        @id @default(cuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  
  number            String        @unique
  
  amount            Decimal       @db.Decimal(10, 2)
  vat               Decimal       @db.Decimal(10, 2) @default(0)
  total             Decimal       @db.Decimal(10, 2)
  currency          String        @default("SAR")
  
  status            InvoiceStatus @default(DRAFT)
  
  providerInvoiceId String?
  pdfUrl            String?
  
  dueAt             DateTime?
  paidAt            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

// ========================================
// NOTIFICATIONS
// ========================================

enum NotificationType {
  TASK_COMPLETED
  TASK_FAILED
  APPROVAL_NEEDED
  NEW_MESSAGE
  NEW_ORDER
  SYSTEM_ALERT
  BILLING_ALERT
  ADMIN_ANNOUNCEMENT
  AGENT_HANDOFF
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String           @db.Text
  
  read      Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  
  createdAt DateTime         @default(now())
  readAt    DateTime?

  @@index([userId, read])
  @@index([companyId, read])
}

// ========================================
// AUDIT LOGS
// ========================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  action     String
  entityType String?
  entityId   String?
  
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([action])
  @@index([createdAt])
}

// ========================================
// SUPPORT TICKETS
// ========================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id           String         @id @default(cuid())
  number       String         @unique
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  subject      String
  description  String         @db.Text
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String?
  assignedToId String?

  messages TicketMessage[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  senderRole  UserRole
  content     String        @db.Text
  attachments Json?
  createdAt   DateTime      @default(now())
}

// ========================================
// PLATFORM SETTINGS (Super Admin)
// ========================================

model PlatformSettings {
  id                 String   @id @default("singleton")
  
  // Branding
  siteName           String   @default("NX iWork")
  siteNameAr         String   @default("NX iWork")
  logoUrl            String?
  primaryColor       String   @default("#06b6d4")
  
  // Deployment mode
  deploymentMode     String   @default("saas")  // "saas" or "single_tenant"
  
  // Features
  signupEnabled      Boolean  @default(true)
  trialEnabled       Boolean  @default(true)
  trialDays          Int      @default(14)
  
  // Financial (SaaS)
  vatRate            Decimal  @db.Decimal(5, 2) @default(15.00)
  defaultCurrency    String   @default("SAR")
  
  // Maintenance
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  
  // SaaS limits (single_tenant ignores these)
  maxCompaniesAllowed Int?    // null = unlimited
  
  updatedAt          DateTime @updatedAt
}
