# =============================================
# NX iWork - Environment Variables
# =============================================
# Copy this to .env.local for development
# Never commit .env files to Git!

# ============ DATABASE ============
DATABASE_URL="postgresql://nxiwork:password@localhost:5432/nxiwork?schema=public"

# ============ NEXTAUTH ============
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ============ ENCRYPTION ============
# Used to encrypt BYOK API keys before storing in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-string-here"

# ============ SCHEDULER (autonomous agents) ============
# Secret that protects POST /api/cron/run. Trigger that endpoint once a minute
# (Coolify Scheduled Task or external cron) so scheduled agent tasks fire. Unset
# = scheduler endpoint disabled. Generate with: openssl rand -hex 32
CRON_SECRET=""

# ============ AI PROVIDERS (BYOK) ============
# Each company brings its own key and picks a provider (Gemini or Claude) in
# Settings — no platform-wide key is required. These optional overrides only
# change which concrete model id each capability tier maps to (see lib/ai/models.ts),
# handy when a provider ships a newer/cheaper model. Defaults shown.
# ANTHROPIC_MODEL_HAIKU="claude-haiku-4-5-20251001"
# ANTHROPIC_MODEL_SONNET="claude-sonnet-4-6"
# ANTHROPIC_MODEL_OPUS="claude-opus-4-8"
# GOOGLE_MODEL_FAST="gemini-2.0-flash"
# GOOGLE_MODEL_BALANCED="gemini-2.0-flash"
# GOOGLE_MODEL_ADVANCED="gemini-2.5-pro"

# ============ AI MODE: byok (default) | managed ============
# byok    = each company uses its own key (no platform cost, no token bank).
# managed = platform pays via Vertex AI (one service account) and meters each
#           company's Company.tokenBalance; requests are blocked at <= 0.
AI_MODE="byok"

# ----- Managed mode only: Google Cloud Vertex AI (service account) -----
# Enable Vertex AI on the GCP project, create a service account with the
# "Vertex AI User" role, download its JSON key, and mount it into the container.
GCP_PROJECT_ID=""
GCP_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS=""   # absolute path to the mounted service-account JSON
# Vertex model ids are region-dependent — override if needed:
# VERTEX_MODEL_FAST="gemini-2.0-flash-001"
# VERTEX_MODEL_BALANCED="gemini-2.0-flash-001"
# VERTEX_MODEL_ADVANCED="gemini-2.5-pro"

# ============ DEPLOYMENT MODE ============
# "saas" = multi-tenant (nx.sa with subscriptions)
# "single_tenant" = one company per deployment (sold license)
DEPLOYMENT_MODE="saas"

# ============ APP CONFIG ============
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NX iWork"
NEXT_PUBLIC_DEFAULT_LANGUAGE="ar"
NEXT_PUBLIC_DEFAULT_THEME="dark"

# ============ EMAIL (Resend) ============
# Transactional + marketing email (lib/notifications/). Unset = email channel
# disabled (flows degrade gracefully).
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@nx.sa"
EMAIL_FROM_NAME="NX iWork"

# ============ SMS (Twilio) ============
# Unset = SMS channel disabled. FROM is either a Twilio number (+1...) or a
# Messaging Service SID (MG...).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# ============ PAYMENT (SaaS phase only) ============
# Leave empty during single_tenant mode
MOYASAR_PUBLIC_KEY=""
MOYASAR_SECRET_KEY=""
MOYASAR_WEBHOOK_SECRET=""

# ============ N8N INTEGRATION (Optional) ============
N8N_BASE_URL=""
N8N_API_KEY=""

# ============ FILE STORAGE — Cloudflare R2 (S3-compatible) ============
# Direct-to-bucket presigned uploads (lib/storage/). Files never transit the
# VPS. R2 has zero egress fees; the same S3 API migrates to AWS S3 / Alibaba OSS
# by changing endpoint + keys only.
R2_ENDPOINT=""            # https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""     # public bucket domain or custom domain, e.g. https://cdn.bznss.one

# ============ FEATURE FLAGS ============
SIGNUP_ENABLED="true"
TRIAL_DAYS="14"
DEFAULT_CURRENCY="SAR"
DEFAULT_TIMEZONE="Asia/Riyadh"

# ============ SECURITY ============
ALLOWED_ORIGINS="http://localhost:3000"
RATE_LIMIT_PER_MINUTE="60"

# ============ EMBEDDINGS (for semantic memory) ============
# Google Gemini embeddings (gemini-embedding-001 @ 1536 dims to match the
# vector(1536) column). Uses an AI Studio key — same Google free tier / credit
# as the rest of the platform. Unset = semantic memory disabled (recall falls
# back to importance-ranked). Platform-level: works even for companies whose
# chat provider is Claude.
GOOGLE_AI_API_KEY=""
# GOOGLE_EMBEDDINGS_MODEL="gemini-embedding-001"

# ============ LOGGING ============
LOG_LEVEL="info"

# ============ DEVELOPMENT ONLY ============
# DEBUG_AGENT_LOOPS="true"
# DEBUG_TOKEN_USAGE="true"
