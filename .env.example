# =============================================
# NX iWork - Environment Variables
# =============================================
# Copy this to .env.local for development
# Never commit .env files to Git!

# ============ DEPLOYMENT ENVIRONMENT ============
# Names the deployment explicitly. A built container runs with NODE_ENV=production
# in BOTH staging and production, so NODE_ENV can't tell them apart — APP_ENV can.
# Everything env-sensitive keys off this: payment test/live keys, search noindex,
# Sentry environment tag, log verbosity. One of: development | staging | production.
#   - development → local Mac (next dev). May leave unset; it falls back here.
#   - staging     → VPS/Coolify pre-live rehearsal. Set staging + use TEST keys.
#   - production  → the live site. Set production + LIVE keys.
# NEXT_PUBLIC_APP_ENV must mirror APP_ENV (the browser needs it for Sentry tagging).
APP_ENV="development"
NEXT_PUBLIC_APP_ENV="development"

# ============ DATABASE ============
# Cap connections to avoid Postgres exhaustion under many concurrent multi-tenant
# agent operations. Add ?connection_limit=N (Prisma) and, for real scale, run
# PgBouncer (transaction mode) in Coolify and point this URL at it. Transaction
# mode is compatible with our RLS `SET LOCAL app.current_tenant_id` (per-tx).
DATABASE_URL="postgresql://nxiwork:password@localhost:5432/nxiwork?schema=public&connection_limit=10"

# ============ NEXTAUTH ============
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ============ SUPER ADMIN ============
# Bootstrap the platform admin entirely from env — set BOTH the email and the
# password (no hidden default in code). On boot the account is created (or its
# password/role reconciled) as SUPER_ADMIN, then you sign in normally. No-op
# until both are set. Password stored bcrypt-hashed; keep these in a secrets
# manager. Edit + redeploy to rotate.
ADMIN_EMAIL="waleed@nx.sa"
ADMIN_PASSWORD="set-a-strong-password"
# ADMIN_NAME="Administrator"
#
# Optional: also elevate already-existing accounts to SUPER_ADMIN by email
# (comma-separated). Emails only — these accounts keep their own passwords.
# SUPER_ADMIN_EMAILS="w@waleed.in,ops@bznss.one"

# ============ ENCRYPTION ============
# Used to encrypt BYOK API keys before storing in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-string-here"

# ============ SCHEDULER (autonomous agents) ============
# Secret that protects POST /api/cron/run. Trigger that endpoint once a minute
# (Coolify Scheduled Task or external cron) so scheduled agent tasks fire. Unset
# = scheduler endpoint disabled. Generate with: openssl rand -hex 32
CRON_SECRET=""

# ============ AI PROVIDERS — model overrides (optional) ============
# The platform default is MANAGED Vertex (below) metered by the token bank; BYOK
# is an opt-in fallback only. These optional overrides just change which concrete
# model id each capability tier maps to (see lib/ai/models.ts), handy when a
# provider ships a newer/cheaper model. Defaults shown.
# ANTHROPIC_MODEL_HAIKU="claude-haiku-4-5-20251001"
# ANTHROPIC_MODEL_SONNET="claude-sonnet-4-6"
# ANTHROPIC_MODEL_OPUS="claude-opus-4-8"
# GOOGLE_MODEL_FAST="gemini-2.0-flash"
# GOOGLE_MODEL_BALANCED="gemini-2.0-flash"
# GOOGLE_MODEL_ADVANCED="gemini-2.5-pro"

# ============ AI MODE: managed (default, Vertex) | byok ============
# managed = the standard path. Platform authenticates to Vertex AI with ONE
#           service account and meters each company's Company.tokenBalance
#           (blocked at <= 0). Uses the $300 GCP free credit.
# byok    = opt-in fallback only: each company uses its own AI Studio/Anthropic
#           key (no token bank). Not used unless you set AI_MODE=byok.
AI_MODE="managed"

# ----- Vertex AI — REQUIRED in managed mode -----
# Enable the Vertex AI API on the GCP project (with billing). Chat AND
# embeddings use it. Only the project + location are needed here — auth is
# keyless (see below).
GCP_PROJECT_ID=""
GCP_LOCATION="us-central1"
#
# Auth resolves automatically via Application Default Credentials (ADC).
# On a non-GCP VPS (Hostinger + Coolify), the cleanest ADC method:
#   1. On the server:  gcloud auth application-default login --no-browser
#   2. cat ~/.config/gcloud/application_default_credentials.json
#   3. Paste that whole JSON into this env var (the app writes it to a temp file
#      and points ADC at it — no file mounts):
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
# Other ADC sources also work (first match wins):
#   - GOOGLE_APPLICATION_CREDENTIALS="/abs/path/to.json"  (mounted file)
#   - gcloud ADC at ~/.config/gcloud/...                  (local dev)
#   - attached service account / Workload Identity        (on GCP)
# Optional inline service-account override (one line, \n preserved, in quotes):
# GCP_CLIENT_EMAIL=""
# GCP_PRIVATE_KEY=""
# Vertex model ids are region-dependent — override if needed:
# VERTEX_MODEL_FAST="gemini-2.0-flash-001"
# VERTEX_MODEL_BALANCED="gemini-2.0-flash-001"
# VERTEX_MODEL_ADVANCED="gemini-2.5-pro"
# VERTEX_EMBEDDINGS_MODEL="gemini-embedding-001"   # semantic memory (1536 dims)
# Gemini 2.5 "thinking" budget (latency/cost vs depth). 0 = off (snappy chat,
# default), N = cap to N tokens, -1 = SDK dynamic default (slowest). Raise if you
# want deeper multi-step reasoning at the cost of slower first-token latency.
# VERTEX_THINKING_BUDGET="0"

# ============ DEPLOYMENT MODE ============
# "saas" = multi-tenant (bznss.one with subscriptions) — the live default
# "single_tenant" = one company per deployment (sold license)
DEPLOYMENT_MODE="saas"

# ============ APP CONFIG ============
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NX iWork"
# Server IPv4 shown in the custom-domain settings as the A-record target for
# apex domains (e.g. the Hostinger VPS IP). Subdomains use a CNAME instead.
NEXT_PUBLIC_APP_IP=""
NEXT_PUBLIC_DEFAULT_LANGUAGE="en"
NEXT_PUBLIC_DEFAULT_THEME="light"

# ============ EMAIL (Resend) ============
# The platform's CENTRAL Resend account — the default sender for all tenants.
# Transactional + marketing (lib/notifications/). Send from the platform's
# verified domain for deliverability; each tenant can override the display name +
# reply-to (and, on higher tiers, their own verified domain) from Settings.
# Unset = email channel disabled (flows degrade gracefully).
RESEND_API_KEY="re_..."
EMAIL_FROM="notify@bznss.one"
EMAIL_FROM_NAME="NX iWork"

# ============ SMS (Twilio) ============
# Unset = SMS channel disabled. FROM is either a Twilio number (+1...) or a
# Messaging Service SID (MG...).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# ============ PAYMENT — Tap.company (SaaS phase only) ============
# Powers wallet top-ups and subscription charges. Set the secret key to enable
# online payments; the webhook re-verifies each charge with it. USE THE KEY THAT
# MATCHES APP_ENV: sk_test_… in development/staging, sk_live_… only in production
# (the boot log warns loudly if these are mismatched).
# TAP_SECRET_KEY="sk_test_..."
# TAP_PUBLIC_KEY="pk_test_..."

# ============ N8N INTEGRATION (Optional) ============
N8N_BASE_URL=""
N8N_API_KEY=""

# ============ FILE STORAGE — Cloudflare R2 (S3-compatible) ============
# Direct-to-bucket presigned uploads (lib/storage/). Files never transit the
# VPS. R2 has zero egress fees; the same S3 API migrates to AWS S3 / Alibaba OSS
# by changing endpoint + keys only.
R2_ENDPOINT=""            # https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""     # public bucket domain or custom domain, e.g. https://cdn.bznss.one

# ============ FEATURE FLAGS ============
SIGNUP_ENABLED="true"
TRIAL_DAYS="14"
DEFAULT_CURRENCY="SAR"
DEFAULT_TIMEZONE="Asia/Riyadh"

# ============ SECURITY ============
ALLOWED_ORIGINS="http://localhost:3000"
RATE_LIMIT_PER_MINUTE="60"

# ============ EMBEDDINGS (semantic memory) ============
# Run on the same Vertex AI service account (see VERTEX section above) —
# gemini-embedding-001 @ 1536 dims. No separate key. Unset Vertex creds =
# semantic memory disabled (recall falls back to importance-ranked).

# ============ ERROR TRACKING (Sentry) ============
# Optional. The SDK is a no-op unless a DSN is set, so dev stays quiet. Set the
# DSNs on staging + production to capture server, edge, and browser errors
# (tagged by APP_ENV). SENTRY_DSN + NEXT_PUBLIC_SENTRY_DSN are the same project
# DSN (server vs browser). The AUTH_TOKEN/ORG/PROJECT are BUILD-time only and
# enable source-map upload for readable stack traces — leave unset to skip it.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# ============ LOGGING ============
LOG_LEVEL="info"

# ============ DEVELOPMENT ONLY ============
# DEBUG_AGENT_LOOPS="true"
# DEBUG_TOKEN_USAGE="true"
